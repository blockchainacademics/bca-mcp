{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-01/server.schema.json",
  "name": "io.github.blockchainacademics/mcp",
  "description": "Canonical crypto MCP — 99 tools spanning news, entities, academy, market data, on-chain, sentiment, proprietary indicators, and agent-backed generation. Wraps api.blockchainacademics.com with attribution envelope on every tool response.",
  "repository": {
    "url": "https://github.com/blockchainacademics/bca-mcp",
    "source": "github"
  },
  "version": "0.2.0",
  "packages": [
    {
      "registry_type": "npm",
      "identifier": "@blockchainacademics/mcp",
      "version": "0.2.0",
      "transport": {
        "type": "stdio"
      },
      "environment_variables": [
        {
          "name": "BCA_API_KEY",
          "description": "BCA API key from api.blockchainacademics.com — free tier issues 2,000 calls/month with mandatory attribution. Get one at https://blockchainacademics.com (dev console launching Q2 2026; contact dev@blockchainacademics.com for early access).",
          "is_required": true,
          "is_secret": true
        },
        {
          "name": "BCA_API_BASE",
          "description": "Override the API base URL. Defaults to https://api.blockchainacademics.com. Only set when testing against staging.",
          "is_required": false,
          "default": "https://api.blockchainacademics.com"
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "tool": {
        "name": "BCA MCP",
        "version": "0.2.0"
      },
      "tool_count": 99,
      "tool_categories": [
        { "name": "Content & corpus", "count": 7, "examples": ["search_news", "get_article", "get_entity", "get_explainer", "list_entity_mentions", "get_as_of_snapshot", "list_topics"] },
        { "name": "Market data", "count": 4, "examples": ["get_price", "get_ohlc", "get_market_overview", "get_pair_data"] },
        { "name": "On-chain", "count": 4, "examples": ["get_wallet_profile", "get_tx", "get_token_holders", "get_defi_protocol"] },
        { "name": "Sentiment", "count": 3, "examples": ["get_sentiment", "get_social_pulse", "get_fear_greed"] },
        { "name": "Proprietary indicators", "count": 6, "examples": ["get_coverage_index", "get_narrative_strength", "get_sentiment_velocity", "get_editorial_premium", "get_kol_influence", "get_risk_score"] },
        { "name": "Agent-backed generation (async)", "count": 6, "examples": ["generate_due_diligence", "generate_tokenomics_model", "summarize_whitepaper", "translate_contract", "monitor_keyword", "get_agent_job"] },
        { "name": "Directories", "count": 13, "examples": ["list_stablecoins", "list_yields", "list_aggregators", "list_mcps", "list_vcs", "list_jobs", "build_custom_indicator"] },
        { "name": "Fundamentals", "count": 6, "examples": ["get_tokenomics", "get_audit_reports", "get_team_info", "compare_protocols", "check_rugpull_risk", "get_roadmap"] },
        { "name": "Chain-specific", "count": 4, "examples": ["get_solana_ecosystem", "get_l2_comparison", "get_bitcoin_l2_status", "get_ton_ecosystem"] },
        { "name": "Microstructure", "count": 5, "examples": ["get_funding_rates", "get_options_flow", "get_liquidation_heatmap", "get_exchange_flows", "predict_listing"] },
        { "name": "Narrative / meta", "count": 5, "examples": ["track_narrative", "get_ai_agent_tokens", "get_depin_projects", "get_rwa_tokens", "get_prediction_markets"] },
        { "name": "Regulatory", "count": 4, "examples": ["get_regulatory_status", "track_sec_filings", "get_mica_status", "get_tax_rules"] },
        { "name": "Security", "count": 4, "examples": ["check_exploit_history", "check_phishing_domain", "get_bug_bounty_programs", "scan_contract"] },
        { "name": "Memes / degen", "count": 4, "examples": ["track_pumpfun", "track_bonkfun", "check_memecoin_risk", "get_degen_leaderboard"] },
        { "name": "Compute / AI crypto", "count": 2, "examples": ["get_compute_pricing", "get_ai_crypto_metrics"] },
        { "name": "Services (revenue)", "count": 3, "examples": ["book_kol_campaign", "request_custom_research", "submit_listing"] },
        { "name": "History time-series", "count": 4, "examples": ["get_history_prices", "get_history_sentiment", "get_history_correlation", "get_history_coverage"] },
        { "name": "Corpus meta", "count": 7, "examples": ["list_entities", "get_topic", "search_academy", "get_trending", "get_unified_feed", "list_sources", "get_recent_stories"] },
        { "name": "Memos / theses / social / currencies", "count": 8, "examples": ["list_memos", "get_memo", "list_theses", "get_thesis", "get_social_signals", "get_social_signals_detail", "list_currencies", "get_currency_feed"] }
      ],
      "homepage": "https://blockchainacademics.com",
      "docs_url": "https://docs.blockchainacademics.com",
      "license": "MIT",
      "categories": ["crypto", "blockchain", "news", "research", "education", "trading", "defi", "on-chain"],
      "authors": [
        {
          "name": "Blockchain Academics",
          "url": "https://blockchainacademics.com",
          "email": "dev@blockchainacademics.com"
        }
      ]
    }
  }
}
